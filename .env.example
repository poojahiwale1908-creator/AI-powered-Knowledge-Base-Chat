# OpenAI API Key (Get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# Model Configuration
LLM_MODEL=gpt-3.5-turbo
TEMPERATURE=0.0
MAX_TOKENS=500

# Document Processing
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Vector Database
CHROMA_PERSIST_DIR=./chroma_db

# Application Settings
SIMILARITY_THRESHOLD=0.3
TOP_K_RESULTS=5
