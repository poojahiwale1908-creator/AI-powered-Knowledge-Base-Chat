        "    file_objects = [FileObj(name, content) for name, content in uploaded.items()]\n",
        "\n",
        "    print(f\"📄 Processing {len(file_objects)} file(s)...\")\n",
        "    stats = pipeline.add_documents(file_objects)\n",
        "    print(f\"✅ Processed: {stats['processed']} files, {stats['chunks']} chunks\")\n",
